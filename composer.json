{
    "name": "shelfwood/laravel-n8n",
    "description": "Tag-based n8n webhook integration for Laravel — fire events, auto-dispatch to matching n8n workflows",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "n8n", "webhooks", "events", "automation", "filament"],
    "homepage": "https://laravel-n8n.shelfwood.co",
    "authors": [
        {
            "name": "Joris Shelfwood",
            "email": "joris@shelfwood.co"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/queue": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0"
    },
    "suggest": {
        "filament/filament": "Required for the N8nStatus admin page (^5.0)"
    },
    "autoload": {
        "psr-4": {
            "Shelfwood\\N8n\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Shelfwood\\N8n\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shelfwood\\N8n\\N8nServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
